generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────── AUTH / USER ───────────

model User {
  id           Int      @id @default(autoincrement())
  userId       String   @unique @db.VarChar(16)
  email        String   @unique
  passwordHash String
  refreshToken String?  @db.VarChar(500)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  role         String   @default("user") @db.VarChar(20)
  isActive     Boolean  @default(true)
  isVerified   Boolean  @default(false)
  lastTokenGeneratedAt DateTime?

  profile     Profile?
  refreshTokens RefreshToken[]

  @@index([email])
  @@index([userId])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  tokenHash String
  userId    String   @db.VarChar(16)
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ─────────── PROFILE ───────────

model Profile {
  userId              String   @id @db.VarChar(16)
  user                User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  firstName           String?  @db.VarChar(50)
  lastName            String?  @db.VarChar(50)
  age                 Int?
  college             String?  @db.VarChar(200)
  qualificationYear   Int?
  address             String?  @db.VarChar(500)
  highestQualification String? @db.VarChar(100)
  profileImage        String?  @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}

// ─────────── QUALIFICATION ───────────

model Qualification {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  isOther   Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("qualifications")
}

// ─────────── VIDEO UPLOAD ───────────

model Video {
  id            Int      @id @default(autoincrement())
  userId        String   @db.VarChar(16)
  user          User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  fileName      String   @db.VarChar(255)
  fileSize      Int
  s3Key         String   @db.VarChar(500)
  s3Url         String   @db.VarChar(500)
  mimeType      String   @db.VarChar(100)
  duration      Float?
  resolution    String?  @db.VarChar(50)
  format        String?  @db.VarChar(20)
  thumbnailKey  String?  @db.VarChar(500)
  thumbnailUrl  String?  @db.VarChar(500)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@map("videos")
}

